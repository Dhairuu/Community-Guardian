# LLM — Primary: Google Gemini (free tier at aistudio.google.com)
GOOGLE_API_KEY=your-key-here
LLM_MODEL=gemini-2.5-flash

# LLM — Fallback: Ollama (local, install from ollama.com)
# Pull a model: ollama pull qwen2.5:7b  (or any model you prefer)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# News Data Source (free tier at newsdata.io — 200 credits/day)
NEWSDATA_API_KEY=your-key-here

# Mode: "synthetic" (uses local JSON) or "live" (uses newsdata.io API)
DATA_MODE=synthetic

# App
APP_HOST=0.0.0.0
APP_PORT=8000
